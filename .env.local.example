# Required. This tool repository is split-mode only.
# Point this to the data directory inside your private ai-session-data repository.
SESSION_DATA_ROOT=C:\path\to\ai-session-data\data

# Optional. The new split repository uses 8788 by default so it can run beside
# the old local project on 8787 during comparison testing.
SESSION_EXPLORER_PORT=8788

# Optional. Required only if you want Kimi / OpenAI-compatible session summaries.
SUMMARY_BASE_URL=https://api.example.com
SUMMARY_API_KEY=replace-with-your-kimi-key
SUMMARY_MODEL=kimi-for-coding
SUMMARY_API_FORMAT=openai
SUMMARY_INPUT_MAX_CHARS=120000
